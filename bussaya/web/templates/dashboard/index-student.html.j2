{% extends '/base/default-dashboard.html.j2' %}
{% import '/base/project-material-renderer.html.j2' as pm_renderer %}

{% block dashboard_title %}
Dashboard
{% endblock %}

{% block breadcrumbs %}
<li><a href="{{ url_for('dashboard.index') }}">Classes</a></li>
{% endblock %}

{% block content %}

<div class="divider divider-start text-lg font-semibold">
  Project
</div>
{% if projects | count > 0 %}
<div class="card bg-base-100 shadow my-4">
  <div class="card-body p-4">
  <h4 class="text-lg font-semibold">Project</h4>
  <ul class="divide-y divide-base-300">
    {% for project in projects %}
    <li class="flex items-center gap-3 py-2">
      <i class="fa-solid fa-laptop fa-lg"></i>
      <div>
        <div class="font-semibold">{{ project.name }}</div>
        <div>
          <i class="fa-solid fa-user"></i>
          {% for s in project.students %}
          {{ s.first_name }} {{ s.last_name }}
          {% if not loop.last %}, {% endif %}
          {% endfor %}

          <i class="fa-solid fa-user-tie"></i> {{ project.advisors|map(attribute='fullname')|join(', ') }}
          {#
          {% if project.is_approval(project.advisor) %}
          <i class="fa-solid fa-check fa-lg text-info"></i>
          {% else %}
          <i class="fa-solid fa-check fa-lg opacity-30"></i>
          {% endif %}
          #}
        </div>
        <div>

          <i class="fa-solid fa-user-gear"></i>
          {% for committee in project.committees %}
          {{ committee.first_name }} {{ committee.last_name }}
          {#
          {% if project.is_approval(committee) %}
          <i class="fa-solid fa-check fa-lg text-info"></i>
          {% else %}
          <i class="fa-solid fa-check fa-lg opacity-30"></i>
          {% endif %}
          #}
          {% endfor %}
        </div>
      </div>
      <div class="ml-auto whitespace-nowrap">
        {{ pm_renderer.render_project_material(project) }}

        {#
        <a class="btn btn-primary" href="{{ url_for('projects.upload', project_id=project.id) }}">Upload</a>}
        #}
        <a href="{{ url_for('projects.view_info_project', project_id=project.id) }}" class="btn btn-primary">View</a>
      </div>
    </li>
    {% endfor %}
  </ul>
  </div>
</div>
{% else %}
<div class="alert alert-info">No projects to display</div>
{% endif %}

<ul class="menu menu-horizontal bg-base-100 rounded-box shadow gap-1">
  <li>
    <a href="{{ url_for('projects.create') }}">
      <i class="fa-solid fa-plus"></i>
      Create Project
    </a>
  </li>
</ul>

<div class="divider divider-start text-lg font-semibold">
  Classes
</div>

{% if available_class %}
<div class="overflow-x-auto">
<table class="table table-zebra">
  <thead>
    <tr>
      <th>Name</th>
      <th>Description</th>
      <th>Type</th>
      <th>Ended Date</th>
    </tr>
  </thead>

  <tbody>
    {% for class_ in available_class%}
    <tr>
      <td>
        <a href="{{ url_for('classes.view', class_id=class_.id) }}">{{ class_.name }}</a>
      </td>
      <td>
        {{ class_.description }}
      </td>
      <td>
        {{ class_.get_type_display() }}
      </td>
      <td>
        {{ class_.ended_date }}
      </td>
    </tr>
    {% endfor %}
  </tbody>
</table>
</div>
{% else %}
<div class="alert alert-info">
  No opened classes to display
</div>
{% endif %}
{% endblock %}
