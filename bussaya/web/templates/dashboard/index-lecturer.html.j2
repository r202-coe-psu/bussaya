{% extends '/base/default-dashboard.html.j2' %}
{% import '/dashboard/project-renderer.html.j2' as renderer %}
{% import '/dashboard/class-attributes.html.j2' as class_attributes %}


{% block dashboard_title %}
Dashboard
{% endblock %}


{% block content %}

<h2 class="divider text-2xl font-bold">Classes</h2>
{% if opened_classes %}
<div class="overflow-x-auto">
<table class="table table-zebra">
  <thead>
    <tr>
      <th>Name</th>
      <th>Description</th>
      {#
      <th>Type</th>
      #}
      <th>Ended Date</th>
      <th></th>
    </tr>
  </thead>

  <tbody>
    {% for class_ in opened_classes %}
    <tr>
      <td>
        <i class="fa-solid fa-{{ class_attributes.class_icons[class_.type]['icon'] }} {{ class_attributes.class_icons[class_.type]['color'] }}"></i>
        <a href="{{ url_for('classes.view', class_id=class_.id) }}">{{ class_.name }}</a>
      </td>
      <td>
        {{ class_.description }}
      </td>
      <td class="whitespace-nowrap">
        {{ class_.ended_date }}
      </td>
      <td class="whitespace-nowrap text-right">
        <div class="tooltip" data-tip="View class">
          <a href="{{ url_for('classes.view', class_id=class_.id) }}" class="btn btn-circle btn-success">
            <i class="fa-solid fa-eye"></i>
          </a>
        </div>
        <div class="tooltip" data-tip="Approve waiting progress report">
          <a href="{{ url_for('classes.approve_meeting_report', class_id=class_.id) }}" class="btn btn-circle btn-info">
            <i class="fa-solid fa-clipboard"></i>
          </a>
        </div>
        <div class="tooltip" data-tip="Midterm grade">
          <a href="{{ url_for('round_grades.view', class_id=class_.id, round_grade_type='midterm') }}" class="btn btn-circle btn-warning" >
            <i class="fa-solid fa-font"></i>
          </a>
        </div>
        <div class="tooltip" data-tip="Final grade">
          <a href="{{ url_for('round_grades.view', class_id=class_.id, round_grade_type='final') }}" class="btn btn-circle btn-error">
            <i class="fa-solid fa-font"></i>
          </a>
        </div>
      </td>
    </tr>
    {% endfor %}
  </tbody>
</table>
</div>
{% else %}
<div class="alert alert-info">
  No opened classes to display
</div>
{% endif %}

{{ renderer.render_project_section(alumni_projects, current_user, advisee_projects, committee_projects) }}

{% endblock %}
