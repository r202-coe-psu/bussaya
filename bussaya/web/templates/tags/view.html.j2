{% extends "/base/default-page.html.j2" %}

{% block content %}

  <div class="container mx-auto px-4">
    <div class="card bg-base-100 shadow my-4">
      <div class="card-body p-4">
      <h3 class="text-xl font-semibold">Tag: {{ name }}</h3>
      <div class="overflow-x-auto">
      <table class="table">
        <tbody>
          {% for project in projects %}
          <tr>
            <td class="w-3/5">
              <b>{{ project.name }}</b><br>
              {{ project.name_th }}</b><br>
              {% for tag in project.tags %}
                <a class="badge badge-sm" href="{{ url_for('tags.view', name=tag) }}">
                  {{ tag }}
                </a>
              {% endfor %}
            </td>
            <td>
              {%- for s in project.students %}
              <i class="fa-solid fa-user"></i>
              <a target="_blank" href="{{ url_for('accounts.profile', user_id=s.id) }}">
                {{ s.first_name }} {{ s.last_name }}
              </a>
              {% if not loop.last %}<br>{% endif %}
              {% endfor -%}
            </td>
            <td class="whitespace-nowrap">
              {%- for type_ in ['report', 'poster', 'presentation', 'video', 'git'] %}
                {% if type_ in project.public %}
                  {% set r = project.get_resource(type_) %}
                  {% if r and r.type == 'report' %}
                    <a target="_blank" class="tooltip" data-tip="Report" href="{{ r.link }}"><i class="fa-solid fa-file-pdf fa-lg"></i></a>
                  {% elif r and r.type == 'poster' %}
                    <a target="_blank" class="tooltip" data-tip="Poster" href="{{ r.link }}"><i class="fa-solid fa-file-image fa-lg"></i></a>
                  {% elif r and r.type == 'presentation' %}
                    <a target="_blank" class="tooltip" data-tip="Rresentation" href="{{ r.link }}"><i class="fa-solid fa-file-powerpoint fa-lg"></i></a>
                  {% elif r and r.type == 'video' %}
                    <a target="_blank" class="tooltip" data-tip="Video" href="{{ r.link }}"><i class="fa-solid fa-file-video fa-lg"></i></a>
                  {% elif r and r.type == 'git' %}
                    <a target="_blank" class="tooltip" data-tip="Git" href="{{ r.link }}"><i class="fa-brands fa-git-alt fa-lg"></i></a>
                  {% endif %}
                {% endif %}
              {%- endfor %}
            </td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
      </div>
      </div>
    </div>
  </div>
{% endblock content %}
