{% extends "/base/default-page.html.j2" %}

{% block title %}Log in{% endblock %}

{% block additional_head %}
{% endblock %}

{% block content %}
<div class="flex items-center justify-center min-h-[70vh]">
  <div class="text-center">
    <h2 class="flex flex-col items-center gap-2 text-5xl font-bold text-accent">
      <img src="{{ url_for('static', filename='images/lotus-full-500px.png') }}" width="200px">
      <div class="content">
        Login
      </div>
    </h2>
    <div>

      <div class="flex flex-col">
{% if 'psu' in oauth_clients %}
        <div class="row p-2">
          <div class="text-left">
            <h3 class="text-xl font-semibold">{{ "For PSU" }}</h3>
          </div>
        </div>
        <div class="row pt-1">
          <a class="btn btn-primary btn-lg" href="{{ url_for('accounts.login_oauth', name='psu') }}">
            <i class="fa-solid fa-user"></i>
            {{ "PSU Passport" }}
          </a>
        </div>
{% endif %}
{% if 'google' in oauth_clients %}
        <div class="row p-2">
          <div class="text-left">
            <h3 class="text-xl font-semibold">{{ "For Participant" }}</h3>
          </div>
        </div>
        <div class="row pt-1">
          <a class="btn btn-error btn-lg" href="{{ url_for('accounts.login_oauth', name='google') }}">
            <i class="fa-brands fa-google"></i>
            {{ "Google" }}
          </a>
        </div>
{% endif %}
      </div>

    </div>
  </div>
</div>
{% endblock %}
