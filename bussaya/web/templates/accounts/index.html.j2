{% if current_user.is_authenticated %}
{% extends '/base/default-dashboard.html.j2' %}
{% else %}
{% extends '/base/default-page.html.j2' %}
{% endif %}

{% block dashboard_title %}
Profile
{% endblock %}

{% block breadcrumbs %}
<li><a href="{{ url_for('accounts.index') }}">Accounts</a></li>
{% endblock %}

{% block title %}
{{ user.title }} {{ user.first_name }} {{ user.last_name }}
{% endblock %}

{% block content %}
<div class="container mx-auto px-4"> {# start div container #}
  <div class="card bg-base-100 shadow my-4">
    <div class="card-body">
    <h2 class="text-2xl font-bold">Profile
      {% if current_user.is_authenticated and current_user.id == user.id %}
      <a class="btn btn-ghost btn-circle btn-sm" href="{{ url_for('accounts.edit_profile') }}"
        title='Edit profile.'><i class="fa-solid fa-pen-to-square"></i></a>
      {% endif %}
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-4 gap-4">

      <div class="text-center">
        <div class="inline-block">
          <img class="w-36 rounded" src="{{ user.get_picture() }}">
        </div>
      </div>

      <div class="md:col-span-3">
        <div>
          <h3 class="text-xl font-semibold">{{ user.title }} {{ user.first_name }} {{ user.last_name }}</h3>
          <h3 class="text-xl font-semibold">{{ user.title_th }} {{ user.first_name_th }} {{ user.last_name_th }}</h3>
          <div class="badge badge-lg">
            <i class="fa-solid fa-envelope"></i>
            {{ user.email }}
          </div>
          <div class="mt-2">
            {% if current_user.is_authenticated and current_user.id == user.id %}
            Role:
            {% for role in user.roles %}
            <div class="badge">
              {{ role }}
            </div>
            {% endfor %}
            {% endif %}
          </div>
        </div>
        <div class="mt-4">
          <h4 class="text-lg font-semibold">Biography</h4>
          {{ biography | safe }}
        </div>
      </div>
    </div>
    </div>
  </div>

  {% set project = user.get_project() %}
  {% if project %}
  <div class="card bg-base-100 shadow my-4">
    <div class="card-body">
    <h3 class="text-xl font-semibold">{{ project.name_th }}</h3>
    <h3 class="text-xl font-semibold">{{ project.name }}</h3>
    <div>
      {% for t in project.tags %}
      <a class="badge" href="{{ url_for('tags.view', name=t) }}">{{ t }}</a>
      {% endfor %}
    </div>
    <div class="alert my-2">
      <div>
        <div class="font-semibold">Advisors</div>
        {% for advisor in project.advisors %}
        <a target="_blank" href="{{ url_for('accounts.profile', user_id=advisor.id) }}">
          {{ advisor.title }} {{ advisor.first_name }} {{ advisor.last_name }}
        </a><br>
      {% endfor %}
      </div>
    </div>
    {% if 'abstract' in project.public %}
    <div class="alert my-2">
      <div>
        <div class="font-semibold">Abstract</div>
        <p>{{ project.abstract_th }}</p>
        <p>{{ project.abstract }}</p>
      </div>
    </div>
    {% endif %}

    {% if project.public not in ['only name', 'private', 'abstract'] %}
    <div class="alert my-2">
      <div>
        <div class="font-semibold">Public</div>
        <p>
        {% for type_, icon in [('report', 'fa-solid fa-file-pdf'), ('poster', 'fa-solid fa-file-image'), ('presentation', 'fa-solid fa-file-powerpoint'),
        ('video', 'fa-solid fa-file-video'), ('git', 'fa-brands fa-git-alt')] %}
          {% if type_ in project.public %}
            {% set r = project.get_resource(type_) %}
            {% if r %}
            <a target="_blank" href="{{ r.link }}" class="tooltip" data-tip="{{ type_.title() }}"><i class="{{ icon }} fa-xl"></i></a>
            {% endif %}
          {% endif %}
        {% endfor %}
        </p>
      </div>
    </div>
    {% endif %}

    {% if current_user.is_authenticated and current_user.has_roles('lecturer') %}
    <div class="alert my-2">
      <div>
        <div class="font-semibold">Special for Lecturer</div>
        <p>
        {% for type_, icon in [('report', 'fa-solid fa-file-pdf'), ('poster', 'fa-solid fa-file-image'), ('presentation', 'fa-solid fa-file-powerpoint'),
        ('video', 'fa-solid fa-file-video'), ('git', 'fa-brands fa-git-alt')] %}
            {% set r = project.get_resource(type_) %}
            {% if r %}
              <a target="_blank" href="{{ r.link }}" class="tooltip" data-tip="{{ type_.title() }}"><i class="{{ icon }} fa-xl"></i></a>
            {% endif %}
        {% endfor %}
        </p>
      </div>
    </div>
    {% endif %}

    </div>
  </div>
    {% endif %}

    {% if 'lecturer' in user.roles %}
    <div class="card bg-base-100 shadow my-4">
      <div class="card-body p-4">
      <div class="overflow-x-auto">
        <table class="table table-zebra">
          <tbody>
            {% for project in user.get_advisee_projects() if project.public != 'private' %}
            <tr>
              <td data-label="Title">{{ project.name }}<br>{{ project.name_th }}</td>
              <td data-label="Student">
                {% for s in project.students %}
                <a target="_blank" href="{{ url_for('accounts.profile', user_id=s.id) }}">
                  {{ s.first_name }} {{ s.last_name }}
                </a>
                {% if not loop.last %}, {% endif %}
                {% endfor %}
              </td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
      </div>
    </div>
    {% endif %}

</div> {# end div container #}
{% endblock %}
