{% extends "/base/default-page.html.j2" %}

{% block content %}

  <div class="container mx-auto px-4">
    <div class="card bg-base-100 shadow my-4">
      <div class="card-body p-4">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <h3 class="text-xl font-semibold">Lecturers</h3>
        </div>
        <div class="text-right">
          <a class="btn btn-primary btn-sm" href="{{ url_for('tags.index') }}"><i class="fa-solid fa-tag"></i>Tags</a>
        </div>
      </div>
      <div class="overflow-x-auto">
      <table class="table">
        <tbody>
          {% for lecturer in lecturers %}
          <tr>
            <td class="w-3/5">
              <a href="{{ url_for('accounts.profile', user_id=lecturer.id) }}">
                <i class="fa-solid fa-user-tie"></i>
                {{ lecturer.title }} {{ lecturer.get_fullname() }}
              </a>
            </td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
      </div>
      </div>
    </div>
  </div>
{% endblock content %}
