{% extends '/admin/classes/index.html.j2' %}
{% import '/base/html-renderer.html.j2' as renderer %}
{% import 'navbar/class-navbar.html.j2' as navbar_renderer %}

{% block breadcrumbs %}
<li><a href="{{ url_for('classes.index') }}">Classes</a></li>
<li><a href="{{ url_for('classes.view', class_id=class_.id) }}">{{ class_.name }}</a></li>
<li><a href="{{ url_for('groups.view', class_id=class_.id) }}">Group</a></li>
{% endblock %}


{% block content %}


{{ navbar_renderer.render_class_navbar(class_, current_user) }}

<h2 class="text-2xl font-bold">Groups</h2>
<div class="divider"></div>

<div class="overflow-x-auto">
    <table class="table table-zebra">
        <thead>
            <th>No.</th>
            <th>Group Name</th>
            <th>Lecturer</th>
            <th>Student IDS </th>
        </thead>
        <tbody>
            {% for group in groups %}
            <tr>
                <td>
                    {{ loop.index }}
                </td>
                <td>
                    {{ group.name }}
                </td>
                <td>
                    {% for lec in group.committees %}
                    {{ lec.get_fullname() }} {% if not loop.last %} <br> {% endif %}
                    {% endfor %}
                </td>
                <td>
                    {{ get_student_ids(group) }}
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>


{% endblock %}

{% block additional_js %}
{% endblock additional_js %}
