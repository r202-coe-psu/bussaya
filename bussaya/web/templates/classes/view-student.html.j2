{% extends '/classes/index.html.j2' %}
{% import '/base/project-material-renderer.html.j2' as project_material_renderer %}

{% block breadcrumbs %}
<li><a href="{{ url_for('dashboard.index') }}">Classes</a></li>
<li><a href="{{ url_for('classes.view', class_id=class_.id) }}">{{ class_.name }}</a></li>
{% endblock %}

{% block content %}
<h1 class="text-3xl font-bold">{{ class_.name }}</h1>

<div class="overflow-x-auto">
<table class="table">
	<tbody>
		<tr>
			<th class="font-medium w-1/6">Description</th>
			<td>{{ class_.description }}</td>
		</tr>
		<tr>
			<th class="font-medium">Code</th>
			<td>{{ class_.code }}</td>
		</tr>
		<tr>
		</tr>
		<tr>
			<th class="font-medium">Started Date</th>
			<td>{{ class_.started_date }}</td>
		</tr>
		<tr>
			<th class="font-medium">Ended Date</th>
			<td>{{ class_.ended_date }}</td>
		</tr>
		<tr>
			<th class="font-medium">Tag</th>
			<td>{{ class_.tags | join(', ') }}</td>
		</tr>
	</tbody>
</table>
</div>

{% if grade_released %}
<div class="card bg-base-100 shadow my-4">
	<div class="card-body p-4">
		<h2 class="text-2xl font-bold">Grade</h2>
		<div class="divider"></div>
		<a class="btn btn-success"
			href="{{ url_for('round_grades.view_student_grades', class_id=class_.id) }}">
			<i class="fa-solid fa-star"></i>
			View Grades
		</a>
	</div>
</div>
{% endif %}


<div class="card bg-base-100 shadow my-4">
	<div class="card-body p-4">

	<h2 class="text-2xl font-bold">Submissions</h2>
	<div class="divider"></div>

	<h3 class="text-xl font-semibold">Meetings</h3>
	{% if meetings | count > 0 %}
	<div class="overflow-x-auto">
	<table class="table table-zebra">
		<thead>
			<tr class="align-top">
				<th>Name</th>
        <th>Round</th>
				<th>Started Date</th>
				<th>Ended Date</th>
				<th>Extended Date</th>
				<th>Status</th>
				<th>Time Remaining</th>
				<th>Action</th>
			</tr>
		</thead>

		<body>
			{% for meeting in meetings %}
			{% set meeting_report = meeting.get_meeting_report_by_owner(user) %}
			<tr class="align-top">
				<td>
					{{ meeting.name }}
				</td>
				<td>
					{{ meeting.get_round_display() }}
				</td>

				<td class="text-right">
					{{ meeting.started_date.strftime("%Y-%m-%d %H:%M") }}
				</td>

				<td class="text-right">
					{{ meeting.ended_date.strftime("%Y-%m-%d %H:%M") }}
        </td>
				<td class="text-right">
					{{ meeting.extended_date.strftime("%Y-%m-%d %H:%M") }}
				</td>



				{# Status #}
				{% if meeting_report %}
				<td class="bg-success/20">
					Submitted
				</td>
				{% else %}

				{% if meeting.get_status() == "opened" %}
				<td class="bg-info/20">
					<a href="{{ url_for('meetings.report', meeting_id=meeting.id)}}">
						Opened
					</a>
				</td>

				{% elif meeting.get_status() == "upcoming" %}
				<td>
					Upcoming
				</td>

				{% else %}
				<td class="bg-error/20">
					Not Submitted
				</td>
				{% endif %}

				{% endif %}


				{% set time_delta, time_remain = meeting.get_remain_time() %}
				<td class="
				{{ 'bg-warning/20' if not meeting_report and time_delta == 1 }}
				{{ 'bg-error/20' if not meeting_report and time_delta == 0 }}
				{{ 'bg-base-300' if time_remain == 'Out of time'}}
				">
					{{ time_remain }}
				</td>

				<td>
					{% if meeting.get_status() == "opened" and meeting_report %}
					<a class="btn btn-primary btn-block"
						href="{{ url_for('meetings.report', meeting_id=meeting.id,  meeting_report_id=meeting_report.id) }}">
						<i class="fa-solid fa-pen-to-square"></i>
						Edit
					</a>
					{% elif meeting.get_status() == "opened" %}
					<a class="btn btn-primary btn-block"
						href="{{ url_for('meetings.report', meeting_id=meeting.id)}}">
						<i class="fa-solid fa-file-lines"></i>
						Report
          </a>
					{% elif meeting.get_status() == "lated" and meeting_report %}
					<a class="btn btn-warning btn-block"
						href="{{ url_for('meetings.late_report', meeting_id=meeting.id, meeting_report_id=meeting_report.id) }}">
						<i class="fa-solid fa-hand"></i>
						Late Report Edit
					</a>

					{% elif meeting.get_status() == "lated" %}
					<a class="btn btn-warning btn-block"
						href="{{ url_for('meetings.late_report', meeting_id=meeting.id)}}">
						<i class="fa-solid fa-hand"></i>
						Late Report
					</a>
					{% endif %}
				</td>
			</tr>
			{% endfor %}
		</body>
	</table>
	</div>
	{% else %}
	<div class="alert alert-info">No meetings at this time.</div>
	{% endif %}

	<div class="divider"></div>
	<h3 class="text-xl font-semibold">Report / Presentation</h3>
	{% if submissions | count > 0 %}
	<div class="overflow-x-auto">
	<table class="table table-zebra">
		<thead>
			<tr class="align-top">
				<th>Type</th>
				<th>Round</th>
        <th>Description</th>
				<th>Started Date</th>
				<th>Ended Date</th>
				<th>Extended Date</th>
				<th>Status</th>
				<th>Time Remaining</th>
				<th>File</th>
				<th>Action</th>
			</tr>
		</thead>

		<body>
			{% for submission in submissions %}
			{% set progress_report = submission.get_progress_report_by_owner(user) %}
			<tr class="align-top">
				<td>
					{{ submission.get_type_display() }}
				</td>
				<td>
					{{ submission.get_round_display() }}
				</td>
				<td>
					{{ submission.description }}
				</td>

				<td>
					{{ submission.natural_started_date() }}
				</td>
				<td>
					{{ submission.natural_ended_date() }}
				</td>
				<td>
					{{ submission.natural_extended_date() }}
				</td>

				{# Status #}
				{% if progress_report %}
				<td class="bg-success/20">
					{{ "Submitted Late" if submission.ended_date < progress_report.updated_date else "Submitted" }}
				</td>
				{% else %}
					{% if submission.get_status() == "opened" %}
				<td class="bg-info/20">
						Opened
				</td>
				{% elif submission.get_status() == "lated" %}
				<td class="bg-warning/20">
						Lated
				</td>
				{% elif submission.get_status() == "closed" %}
				<td class="bg-error/20">
					Not Submitted
				</td>
				{% elif submission.get_status() == "upcoming" %}
				<td>
					Upcoming
				</td>
				{% endif %}
				{% endif %}


				{% set time_delta, time_remain = submission.get_remain_time() %}
				<td class="
				{{ 'bg-warning/20' if time_delta == 1 and not progress_report }}
				{{ 'bg-error/20' if time_delta == 0 and not progress_report }}
				{{ 'bg-base-300' if time_remain == 'Out of time'}}
				">
					{{ time_remain }}
				</td>

				<td>
					{% if progress_report %}
					<a href="{{ url_for('submissions.download', progress_report_id=progress_report.id, filename=progress_report.file.filename) }}"
						target="_blank">
						{{ progress_report.file.filename }}
					</a>
					{% else %}
					-
					{% endif %}
				</td>

				<td>
					{% if (submission.get_status() == "opened" or submission.get_status() == "lated") and submission.get_type_display()=="Report" %}
					<a class="btn btn-sm btn-block {{ 'btn-primary' if current_user.get_permission_to_upload(submission) else 'btn-disabled' }}" href="{{ url_for('submissions.upload', submission_id=submission.id)}}">
						<i class="fa-solid fa-upload"></i>
					  	Upload
					</a>

					{% elif (submission.get_status() == "opened" or submission.get_status() == "lated") and submissions[loop.index-2].get_progress_report_by_owner(user) and submission.get_type_display()=="Presentation" %}

					<a class="btn btn-sm btn-block {{ 'btn-primary' if current_user.get_permission_to_upload(submission) else 'btn-disabled' }}" href="{{ url_for('submissions.upload', submission_id=submission.id)}}">
						<i class="fa-solid fa-upload"></i>
						Upload
					</a>

					{% else %}
					<a class="btn btn-sm btn-block btn-disabled">
						<i class="fa-solid fa-upload"></i>
						  Upload
					</a>



					{% endif %}


				</td>
			</tr>
			{% endfor %}
		</body>
	</table>
	</div>
	{% else %}
	<div class="alert alert-info">No submission at this time.</div>
{% endif %}


{% if final_submission %}
<div class="card bg-base-100 shadow my-4">
  <div class="card-body p-4">
  <h2 class="text-2xl font-bold">Completed Final Report</h2>
  {% if project %}
    <div class="divider"></div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div class="card bg-base-100 shadow">
        <div class="card-body p-4">
        {{ project.name }}
        </div>
      </div>
      <div class="card bg-base-100 shadow">
        <div class="card-body p-4">
        {{ project_material_renderer.render_project_material(project) }}
        </div>
      </div>
    </div>
  {% endif %}
	<div class="divider"></div>
	<a class="btn btn-primary"
		href="{{ url_for('final_reports.upload', final_submission_id=final_submission.id) }}">
		<i class="fa-solid fa-upload"></i>
		Upload Final Report
	</a>
  </div>
</div>
{% endif %}

	</div>
</div>

{% endblock %}
