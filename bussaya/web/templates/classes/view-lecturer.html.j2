{% extends '/classes/index.html.j2' %}

{% import '/base/error-handler.html.j2' as eh %}
{% import '/base/html-renderer.html.j2' as renderer %}
{% import '/navbar/class-navbar.html.j2' as renderer_navbar %}
{% import '/dashboard/project-renderer.html.j2' as renderer_project %}

{% block breadcrumbs %}
<li><a href="{{ url_for('classes.index') }}">Classes</a></li>
<li><a href="{{ url_for('classes.view', class_id=class_.id) }}">{{ class_.name }}</a></li>
{% endblock %}


{% block content %}

{{ renderer_navbar.render_class_navbar(class_, current_user) }}

<h2 class="text-2xl font-bold">Class</h2>
<div class="divider"></div>

<div class="overflow-x-auto">
<table class="table">
  <tbody>
    <tr>
      <td>
        <div class="text-sm opacity-70">NAME </div>{{ class_.name }}
      </td>
      <td>
        <div class="text-sm opacity-70">DESCRIPTION</div> {{ class_.description }}
      </td>
    </tr>
    <tr>
      <td>
        <div class="text-sm opacity-70">OWNER </div>{{ class_.owner.first_name }} {{ class_.owner.last_name }}
      </td>
      <td>
        <div class="text-sm opacity-70">CODE </div>{{ class_.code }}
      </td>
    </tr>
    <tr>
      <td>
        <div class="text-sm opacity-70">TYPE</div> {{ class_.get_type_display() }}
      </td>
      <td>
        <div class="text-sm opacity-70">TAG</div> {{ class_.tags | join(', ') }}
      </td>
    </tr>
    <tr>
      <td>
        <div class="text-sm opacity-70">STARTED DATE</div> {{ class_.started_date }}
      </td>
      <td>
        <div class="text-sm opacity-70">ENDED DATE</div> {{ class_.ended_date }}
      </td>
    </tr>
  </tbody>
</table>
</div>


<div class="card bg-base-100 shadow my-4">
  <div class="card-body p-4">
    <h2 class="text-2xl font-bold">Submissions</h2>
    <div class="divider"></div>
    <h3 class="text-xl font-semibold">Meeting</h3>
    <div class="overflow-x-auto">
    <table class="table table-zebra">
      <thead>
        <tr>
          <th>ID</th>
          <th>Name</th>
          <th>Midterm</th>
          <th>Final</th>
          <th></th>
        </tr>
      </thead>

      <tbody>
        {% for student in current_advisees %}
          <tr>
            <td>
              {{ student.username }}
            </td>
            <td>
              {{ student.first_name }} {{ student.last_name }}
            </td>
            <td>
              <div class="badge badge-success">
                <i class="fa-solid fa-check"></i> {{ student.get_meeting_reports(class_, 'midterm', 'approved').count() }}
              </div>

              <div class="badge badge-primary">
                <i class="fa-solid fa-clipboard"></i> {{ student.get_meeting_reports(class_, 'midterm').count() }}
              </div>
            </td>
            <td>
              <div class="badge badge-success">
                <i class="fa-solid fa-check"></i> {{ student.get_meeting_reports(class_, 'final', 'approved').count() }}
              </div>

              <div class="badge badge-primary">
                <i class="fa-solid fa-clipboard"></i> {{ student.get_meeting_reports(class_, 'final').count() }}
              </div>

            </td>
            <td>
              <a href="{{ url_for('classes.list_report_by_user', class_id=class_.id, user_id=student.id) }}" class="btn btn-primary btn-circle">
                <i class="fa-solid fa-eye"></i>
              </a>
            </td>
        {% endfor %}
      </tbody>
    </table>
    </div>



    <div class="divider"></div>

    <h3 class="text-xl font-semibold">Report / Presentation</h3>
    {{ renderer_project.render_project_section([], current_user, advisee_projects, committee_projects) }}
  </div>
</div>

{% if projects %}
<div class="card bg-base-100 shadow my-4">
  <div class="card-body p-4">
    <h2 class="text-2xl font-bold">Final Report</h2>
    {{ renderer_project.render_project_table(projects, current_user) }}
  </div>
</div>
{% endif %}
{% endblock %}
