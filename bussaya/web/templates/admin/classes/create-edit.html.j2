{% extends '/base/default-dashboard.html.j2' %}
{% import '/base/html-renderer.html.j2' as renderer %}
{% import '/navbar/class-navbar.html.j2' as renderer_navbar %}

{% block dashboard_title %}
	{% if 'admin.classes.create' == request.endpoint %}
		Create
	{% elif 'admin.classes.edit' == request.endpoint %}
		Edit
	{% elif 'admin.classes.copy' == request.endpoint %}
		Copy
	{% endif %}
	Classes
{% endblock %}

{% block breadcrumbs %}
{% if class_ %}
<li><a href="{{ url_for('admin.classes.index') }}">Classes</a></li>
<li><a href="{{ url_for('admin.classes.view', class_id=class_.id) }}">{{ class_.name }}</a></li>

{% if 'admin.classes.edit' == request.endpoint %}
<li><a href="{{ url_for('admin.classes.edit', class_id=class_.id) }}">Edit</a></li>
{% elif 'admin.classes.copy' == request.endpoint %}
<li><a href="{{ url_for('admin.classes.copy', class_id=class_.id) }}">Copy</a></li>
{% endif %}
{% else %}
<li><b>Create Classes</b></li>
{% endif %}
{% endblock %}


{% block content %}
{% if class_ %}

{{ renderer_navbar.render_class_navbar(class_, current_user) }}

<h2 class="text-2xl font-bold">Edit Class</h2>
<div class="divider"></div>
{% endif %}

<div class="row">
  <div class="card bg-base-100 shadow my-4">
    <div class="card-body p-4">
      <form method="POST" class="space-y-1">
        {{ form.csrf_token }}
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {{ renderer.render_field(form.name) }}
          <div>
            {{ renderer.render_field(form.code) }}
          </div>
        </div>
        {{ renderer.render_field(form.description) }}
        {{ renderer.render_field(form.student_ids) }}

        {{ renderer.render_field(form.tags) }}
        {{ renderer.render_select(form.type) }}
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {{ renderer.render_date_picker(form.started_date, 'rangestart') }}
          {{ renderer.render_date_picker(form.ended_date, 'rangeend') }}
        </div>
        <button name="create" type="submit" class="btn btn-primary">
          {{ 'Create' if 'create' in request.path else 'Edit'}}
        </button>
      </form>
    </div>
  </div>
</div>


{% endblock %}
