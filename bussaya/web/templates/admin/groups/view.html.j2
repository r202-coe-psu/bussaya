{% extends '/admin/classes/index.html.j2' %}
{% import '/base/html-renderer.html.j2' as renderer %}
{% import 'navbar/class-navbar.html.j2' as navbar_renderer %}

{% block breadcrumbs %}
<li><a href="{{ url_for('admin.classes.index') }}">Classes</a></li>
<li><a href="{{ url_for('admin.classes.view', class_id=class_.id) }}">{{ class_.name }}</a></li>
<li><a href="{{ url_for('admin.groups.manage', class_id=class_.id) }}">Group</a></li>
{% endblock %}


{% block content %}


{{ navbar_renderer.render_class_navbar(class_, current_user) }}

<h2 class="text-2xl font-bold">Manage Groups</h2>
<div class="divider"></div>


<div class="card bg-base-100 shadow my-4">
  <div class="card-body p-4">
  <div class="overflow-x-auto">
  <table class="table table-zebra">
    <thead>
      <tr>
        <th>No.</th>
        <th>Lecturer</th>
        <th>Student</th>
        <th>Amount</th>
      </tr>
    </thead>
    <tbody>
      {% for group in groups %}
      <tr class="align-top">
        <td>
          {{ loop.index }}
        </td>
        <td>
          {% for committee in group['committees'] %}
          {{ committee.get_fullname() }} {% if not loop.last %} <br> {% endif %}
          {% endfor %}
        </td>
        <td>
          {% for student in group['students'] %}
          {{ student.username }} - {{ student.get_fullname() }}<br>
          {% endfor %}
        </td>
        <td>
          {{ group['students'] | length }}
        </td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  </div>
  </div>
</div>


{% endblock %}
