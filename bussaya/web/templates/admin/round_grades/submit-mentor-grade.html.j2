{% extends '/admin/classes/index.html.j2' %}
{% import '/base/error-handler.html.j2' as eh %}
{% import '/base/html-renderer.html.j2' as renderer %}
{% import '/navbar/class-navbar.html.j2' as renderer_navbar %}
{% import '/admin/round_grades/admin-grade-menu-toolbars.html.j2' as render_toolbars %}

{% block breadcrumbs %}
<li><a href="{{ url_for('admin.classes.index') }}">Classes</a></li>
<li><a href="{{ url_for('admin.classes.view', class_id=class_.id) }}">{{ class_.name }}</a></li>
<li>
    <a href="{{ url_for('admin.round_grades.view', class_id=class_.id, round_grade_type=round_grade.type) }}">
        {{ round_grade.get_type_display() }}
    </a>
</li>
<li>Mentor Grading</li>
{% endblock %}


{% block content %}

{{ renderer_navbar.render_class_navbar(class_, current_user) }}

{{ render_toolbars.render_admin_grade_menu_toolbars(round_grade) }}

<form method="POST" id="form-round_grade">
    {{ form.csrf_token }}
    <div class="pt-4">
        <div class="overflow-x-auto">
        <table class="table table-zebra">
            <thead>
                <tr>
                    <th></th>
                    <th>Student ID / Student Name</th>
		                <th>Advisors</th>
		                <th>Project</th>
                    <th>Mentor</th>
                    <th>Grading</th>
                    <th>Average Grade</th>
                    <th>Final Grade</th>
                    <th>Total Grade</th>
                </tr>
            </thead>
            <tbody>
                {% for student_grade in student_grades %}
                {% set student = student_grade.student %}
                <tr class="align-top">
                  <td>{{ loop.index }}</td>
                  <td>{{ student.username }} <br/>
                    {{ student.first_name }} {{ student.last_name }}<br/>
                    {{ student.first_name_th }} {{ student.last_name_th }}
		              </td>
                    <td>
                      {{ student.get_project().advisors|map(attribute='fullname')|join(', ') }}
                    </td>
                    <td>
                      {{ student_grade.project.name }}<br/>
                      {{ student_grade.project.name_th }}
                    </td>
                    <td>
                        {% set grading = form.gradings[loop.index - 1] %}
                        <div id="{{ grading.id }}" style="width: auto">
                            {{ grading.mentor_id(class_="select w-full") }}
                        </div>

                    </td>
                    <td>
                        {% set grading = form.gradings[loop.index - 1] %}
                        <div id="{{ grading.id }}" style="width: auto">
                            {{ grading.student_id }}
                            {{ grading.result(class_="select w-full") }}
                        </div>
                    </td>
                    <td>{{ student.get_average_grade(student_grade.round_grade) }}</td>
                    {% set actual_grade, caused = student.get_actual_grade(student_grade.round_grade) %}
                    <td>
                      {% if not caused %}
                        {{ actual_grade }}
                      {% else %}
                        <div class="collapse collapse-arrow bg-base-100">
                            <input type="checkbox">
                            <div class="collapse-title p-1 min-h-0">
                                {{ actual_grade }}
                            </div>
                            <div class="collapse-content text-sm" style="width: fit-content">
                                {% for cause in caused %}
                                - {{ cause }}
                                {% if not loop.last %} <br> {% endif %}
                                {% endfor %}
                            </div>
                        </div>
                      {% endif %}
                    </td>
                    <td>
                        <div class="title">
                            <a id="{{ student_grade.id }}" style="cursor: pointer"
                                onclick="accordion_show_hide('{{student_grade.id}}')">
                                See More
                            </a>
                        </div>
                        <div id="{{ student_grade.id }} content" class="content hidden">
                            <p />
                            {% for student_grade in student.get_total_student_grades(round_grade) %}
                            <ul class="space-y-1">
                                <li class="flex items-center gap-2">
                                    {% if student_grade.get_grader() and student_grade.get_grader().get_picture() %}
                                    <div class="avatar">
                                        <div class="w-8 rounded-full">
                                            <img src="{{ student_grade.get_grader().get_picture() }}">
                                        </div>
                                    </div>
                                    {% else %}
                                    <i class="fa-solid fa-user"></i>
                                    {% endif %}
                                    <div>
                                      <a class="font-semibold">
                                        {% if student_grade.get_grader() %}
                                          {{ student_grade.get_grader().get_full_name() }}
                                          {% if student_grade.get_grader() in student.get_project().advisors %}
                                            <i class="fa-solid fa-star text-error"></i>
                                          {% elif student_grade.grader.mentor %}
                                            <i class="fa-solid fa-star text-info"></i>
                                          {% endif %}
                                        {% else %}
                                            Unknow Grader
                                        {% endif %}
                                      </a>
                                      <div class="text-sm opacity-70">{{ student_grade.get_result_display() }}</div>
                                    </div>
                                </li>
                            </ul>
                            {% endfor %}
                        </div>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
        </div>
    </div>
    <div class="mb-20">
        <button type="submit" class="btn btn-primary btn-lg float-right mt-4" id="submit-button">
            <i class="fa-solid fa-floppy-disk"></i> Save
        </button>
    </div>
</form>

{% endblock %}


{% block additional_js %}
<script type="text/javascript">
    function accordion_show_hide(show_hide_id) {
        document.getElementById(show_hide_id + " content").classList.toggle('hidden')

        if (document.getElementById(show_hide_id).textContent == "Hide") {
            document.getElementById(show_hide_id).innerHTML = "See More"
        } else {
            document.getElementById(show_hide_id).innerHTML = "Hide"
        }
    }
</script>
{% endblock additional_js %}
