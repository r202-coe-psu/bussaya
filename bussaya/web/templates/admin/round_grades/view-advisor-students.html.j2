{% extends '/admin/classes/index.html.j2' %}
{% import '/base/error-handler.html.j2' as eh %}
{% import '/base/html-renderer.html.j2' as renderer %}
{% import '/navbar/class-navbar.html.j2' as renderer_navbar %}
{% import '/admin/round_grades/admin-grade-menu-toolbars.html.j2' as render_toolbars %}


{% block breadcrumbs %}
{% set student = student_grades[0].student %}
<li><a href="{{ url_for('admin.classes.index') }}">Classes</a></li>
<li><a href="{{ url_for('admin.classes.view', class_id=class_.id) }}">{{ class_.name }}</a></li>
<li>
  <a href="{{ url_for('admin.round_grades.view', class_id=class_.id, round_grade_type=round_grade.type) }}">
      {{ round_grade.get_type_display() }}
  </a>
</li>
<li>
  <a href="{{ url_for('admin.round_grades.view_total', class_id=class_.id, round_grade_type=round_grade.type) }}">View
      Total
      Grade
  </a>
</li>
<li>
  <a href="{{ url_for('admin.round_grades.view_advisor_students', round_grade_type=round_grade.type, class_id=class_.id, advisor_id=advisor.id) }}">View
    Advisor
    Students
  </a>
</li>
{% endblock %}

{% block content %}



  <div class="card bg-base-100 shadow my-4">
    <div class="card-body p-4">
      <h2 class="text-2xl font-bold">Profile

        <a class="btn btn-circle btn-sm" href="/accounts/edit-profile" title="Edit profile."><i class="fa-solid fa-pen-to-square"></i></a>
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-4 gap-4">

        <div class="text-center">
          <img class="w-40 rounded-box inline-block" src="{{ advisor.get_picture() }}">
        </div>
        <div class="md:col-span-3">
          <div>
              <h3 class="text-xl font-semibold">{{ advisor.title }} {{ advisor.first_name }} {{ advisor.last_name }}</h3>
              <h3 class="text-xl font-semibold">{{ advisor.title_th }} {{ advisor.first_name_th }} {{ advisor.last_name_th }}</h3>
              <div class="badge badge-lg">
                <i class="fa-solid fa-envelope"></i>
                {{ advisor.email }}
              </div>
              <div class="mt-1">
                Role:
                {% for role in advisor.roles %}
                <div class="badge">
                  {{ role }}
                </div>
                {% endfor %}
              </div>
            </div>
          <div class="mt-4">
            <h4> Biography </h4>
            {{ advisor.Biography }}
          </div>
        </div>
      </div>
    </div>
  </div>


<div class="card bg-base-100 shadow my-4">
  <div class="card-body p-4">
  <div class="overflow-x-auto">
  <table class="table table-zebra">
    <thead>
      <tr class="align-top">
        <th>  </th>
        <th> ID </th>
        <th> Student </th>
        <th> project name </th>
      </tr>
    </thead>
    <tbody>
      {% for project_info in project_infos  %}
      <tr class="align-top">
        <td>
          {{ loop.index }}
        </td>
        <td>
          <a target="_blank" href="{{ url_for('accounts.profile', user_id=project_info['student'].id) }}">
          {{ project_info["student"].username }}
          </a>
        </td>
        <td>
          <a href="{{ url_for('admin.projects.edit', project_id=project_info['student'].get_project().id) }}" class="btn btn-primary btn-circle btn-sm"><i class="fa-solid fa-laptop-code"></i></a>
          <a href="{{ url_for('accounts.profile', user_id=project_info['student'].id) }}">
            {{ project_info["student"].first_name }} {{ project_info["student"].last_name }}
          </a>
        </td>
        <td>
          <a href="{{ url_for('projects.view', project_id=project_info['project'].id) }}">
            {{ project_info["project"].name }}<br>{{ project_info["project"].name_th }}
          </a>
        </td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  </div>
  </div>
</div>


{% endblock %}
