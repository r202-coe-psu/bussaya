{% extends '/base/default-dashboard.html.j2' %}

{% block dashboard_title %}
Users
{% endblock %}

{% block breadcrumbs %}
<li><a href="{{ url_for('admin.users.index') }}">Users</a></li>
{% endblock %}

{% block content %}

<div class="row">
    {% if users %}
    <div class="overflow-x-auto">
    <table class="table table-zebra">
        <thead>
            <tr>
                <th>Name</th>
                <th>ID</th>
                <th>Edit</th>
            </tr>
        </thead>

        <body>
            {% for user in users %}
            <tr>
                <td>
                    <a href="{{ url_for('admin.users.view', user_id=user.id) }}">
                        {{ user.first_name + " " + user.last_name }}
                    </a>
                </td>
                <td>
                    {{ user.username }}
                </td>
                <td>
                    <a href="{{ url_for('admin.users.view', user_id=user.id) }}">
                        Edit
                    </a>
                </td>
            </tr>
            {% endfor %}
        </body>
    </table>
    </div>
    {% endif %}

</div>

{% endblock %}