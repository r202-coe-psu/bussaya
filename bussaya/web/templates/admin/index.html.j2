{% extends '/base/default-dashboard.html.j2' %}
{% import '/base/project-material-renderer.html.j2' as pm_renderer %}

{% block content %}
{#
<div class="card bg-base-100 shadow min-h-[80vh] pt-[10vh]">
  <div class="text-center">
    <i class="fa-solid fa-building-columns"></i>
    <h3>Hello, {{ current_user.first_name }} {{ current_user.last_name }} </p>
    <div>
      <a class="btn btn-primary" href="{{ url_for('classes.index') }}">Class</a>
      <a class="btn btn-primary" href="{{ url_for('votings.index') }}">View Vote</a>
      <a class="btn btn-primary" href="{{ url_for('elections.index') }}">Manage Election</a>
    </div>
  </div>
</div>
#}

<h4 class="text-lg font-semibold">Class: {{ class_.name }}</h4>
<div class="overflow-x-auto">
<table class="table table-zebra">
  <thead>
    <tr>
      <th>No.</th>
      <th>Name</th>
      <th>Students</th>
      <th>Advisor</th>
      <th>Public</th>
      <th>Document</th>
      <th>Approve</th>
    </tr>
  </thead>
  <tbody>

    {% for project in projects %}
    <tr>
      <td>{{ loop.index }}</td>
      <td>
        <a target="_blank" href="{{ url_for('projects.view', project_id=project.id) }}">
          {{ project.name }}
        </a>
      </td>
      <td>
        {%- for s in project.students %}
        <a target="_blank" href="{{ url_for('accounts.profile', user_id=s.id) }}">
          {{ s.first_name }} {{ s.last_name }}
        </a>
        {% if not loop.last %}, {% endif %}
        {% endfor -%}
      </td>
      <td>
        {% for advisor in project.advisors %}
        <a target="_blank" href="{{ url_for('accounts.profile', user_id=advisor.id) }}">
          {{ advisor.first_name }} {{ advisor.last_name }}
        </a>
      </td>
        <td>{{ project.public.title() }}</td>
        <td class="whitespace-nowrap">
          {{ pm_renderer.render_project_material(project) }}
        </td>
        <td class="whitespace-nowrap">
          {% for committee in project.advisors + project.committees %}
            {{ committee.first_name }}
            {% if project.is_approval(committee) %}
              <i class="fa-solid fa-check fa-lg text-info"></i>
            {% else %}
              <i class="fa-solid fa-check fa-lg opacity-30"></i>
            {% endif %}
            <br>
          {% endfor %}
        </td>
        {% endfor %}
    </tr>
  	{% endfor %}

  </tbody>
</table>
</div>

{% endblock %}
